{
  "name": "chronoatlas",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "validate:data": "node scripts/validate-data.mjs && npm run validate:db",
    "validate:db": "node --no-warnings scripts/build-history-db.mjs --check",
    "db:build": "node --no-warnings scripts/build-history-db.mjs",
    "db:export": "node --no-warnings scripts/export-history-data.mjs",
    "db:rebuild": "npm run db:build && npm run db:export"
  },
  "dependencies": {
    "d3-geo": "^3.1.1",
    "d3-shape": "^3.2.0",
    "lucide-react": "^0.561.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "three": "^0.184.0",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2"
  },
  "devDependencies": {
    "@turf/bbox-clip": "^7.3.5",
    "@types/d3-geo": "^3.1.0",
    "@types/d3-shape": "^3.1.8",
    "@types/geojson": "^7946.0.16",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@types/topojson-client": "^3.1.5",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.16"
  }
}
