{
  "name": "chronoatlas",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "api": "node --no-warnings scripts/history-api-server.mjs",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "validate:data": "npm run db:build && node --no-warnings scripts/validate-data.mjs && npm run validate:db",
    "validate:db": "node --no-warnings scripts/build-history-db.mjs --check",
    "audit:imports": "node --no-warnings scripts/audit-import-drafts.mjs",
    "import:staging": "node --no-warnings scripts/import-evidence-cards-staging.mjs",
    "import:china-map": "node --no-warnings scripts/import-china-map-runtime.mjs",
    "import:china-physical": "node --no-warnings scripts/import-natural-earth-china-runtime.mjs",
    "audit:china-map-geometry": "node --no-warnings scripts/audit-map-geometry-china-190-280.mjs",
    "import:china-map-geometry": "node --no-warnings scripts/import-map-geometry-china-190-280.mjs",
    "import:roman-map-geometry": "node --no-warnings scripts/import-map-geometry-roman-190-310.mjs",
    "import:roman-event-map-links": "node --no-warnings scripts/import-roman-event-map-links.mjs",
    "db:seed:export": "node --no-warnings scripts/export-sqlite-seed.mjs",
    "db:build": "node --no-warnings scripts/build-history-db.mjs",
    "db:export": "node --no-warnings scripts/export-history-data.mjs",
    "db:rebuild": "npm run db:build && npm run db:export"
  },
  "dependencies": {
    "d3-geo": "^3.1.1",
    "d3-shape": "^3.2.0",
    "lucide-react": "^0.561.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "three": "^0.184.0",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2"
  },
  "devDependencies": {
    "@turf/bbox-clip": "^7.3.5",
    "@types/d3-geo": "^3.1.0",
    "@types/d3-shape": "^3.1.8",
    "@types/geojson": "^7946.0.16",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@types/topojson-client": "^3.1.5",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.16"
  }
}
